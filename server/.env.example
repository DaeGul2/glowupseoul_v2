PORT=3001
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_MODEL=gpt-4o-mini
# Allowed origins, comma-separated. * = open (dev only)
CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174
# Cap inbound JSON size — image base64 is the biggest payload
MAX_BODY_MB=8
# Google Places API (New) — for /api/reviews
GOOGLE_PLACES_API_KEY=
REVIEWS_CACHE_HOURS=24
# Admin key for /api/partner/admin listing — long random string
ADMIN_KEY=

# ---- AWS RDS MySQL ----
# RDS endpoint, e.g. glowupseoul-prod.cluster-xxxx.ap-northeast-2.rds.amazonaws.com
DB_HOST=
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=
DB_NAME=glowupseoul
DB_CHARSET=utf8mb4
DB_CONNECTION_LIMIT=10
# 'rds' = use bundled AWS RDS CA (recommended). 'true' = generic TLS. 'false' = no TLS (dev only).
DB_SSL_MODE=rds
DB_SSL_CA_PATH=

# ---- AWS S3 (image uploads from admin) ----
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_MAX_UPLOAD_MB=10
