# 기본은 git 알아서. 단 shell/yml 같은 Unix-essential 파일은 LF 강제.
* text=auto

# 줄바꿈이 CRLF 면 bash/yaml 이 깨짐. 강제 LF.
*.sh           text eol=lf
*.bash         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
Dockerfile     text eol=lf
.env*          text eol=lf
nginx*.conf    text eol=lf

# 바이너리 (텍스트 diff 의미 없음 → binary 처리)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.svg   text
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.pptx  binary
*.docx  binary
*.zip   binary
*.gz    binary
*.tar   binary
*.mp4   binary
*.webm  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pem   binary
